# ===== neopuck Bridge — Konfiguration =====

# --- Bridge <-> Device (neopuck verbindet sich hierher) ---
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
# optional: muss zum agent_token im neopuck passen (leer = keine Pruefung)
NEOPUCK_TOKEN=

# --- openclaw (das "Gehirn", Variante 2) ---
OPENCLAW_WS=wss://new.bornholz.com/kite/ws?session=neopuck-bridge
OPENCLAW_USER=fredl
OPENCLAW_PASS=
OPENCLAW_GATEWAY_TOKEN=

# --- OpenAI (Stimme: STT/TTS) ---
# Nur noetig, falls openclaws talk.*-API NICHT direkt Audio liefert.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy
