# ===== neopuck Bridge — Konfiguration =====

# --- Bridge <-> Device (neopuck verbindet sich hierher) ---
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
# optional: muss zum agent_token im neopuck passen (leer = keine Pruefung)
NEOPUCK_TOKEN=

# --- openclaw (Gehirn UND Stimme, Variante 2 = Standard) ---
OPENCLAW_WS=wss://new.bornholz.com/kite/ws?session=neopuck-bridge
OPENCLAW_USER=fredl
OPENCLAW_PASS=
OPENCLAW_GATEWAY_TOKEN=
# konfigurierter Sprach-Provider in openclaw (aktuell: microsoft)
OPENCLAW_TALK_PROVIDER=microsoft

# --- OpenAI: NUR fuer die alternative Bridge neopuck_openai_bridge.py noetig ---
# (Standard-Bridge neopuck_openclaw_bridge.py braucht KEIN OpenAI.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy
